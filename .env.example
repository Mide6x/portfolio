# ====== Public Frontend Configuration File ======
# Do not place real production passwords here! This serves as a template.

# Admin Passkey (Required to access the /admin portal UX)
VITE_ADMIN_PASSWORD=your_secure_password_here

# Backend Origin Endpoint (Point this to your deployed Backend proxy, e.g. Coolify)
VITE_API_BASE_URL=https://your-deployed-backend-domain.com

# Supabase Context 
# (Currently not strictly required because the Backend securely handles DB logic inherently)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
